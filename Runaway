<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>RunawayNandan - 2D Mobile Game</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;font-family:Arial,sans-serif}
body{min-height:100vh;background:linear-gradient(135deg,#0f172a,#1d4ed8);display:flex;justify-content:center;align-items:center;color:white;overflow:hidden}
.game-wrapper{width:100%;max-width:430px;height:100vh;max-height:820px;padding:12px;display:flex;flex-direction:column;gap:10px}
.top-bar{display:flex;justify-content:space-between;align-items:center;background:linear-gradient(135deg,rgba(15,23,42,.9),rgba(37,99,235,.72));border:1px solid rgba(255,255,255,.22);border-radius:20px;padding:10px 12px;box-shadow:0 8px 25px rgba(0,0,0,.25)}
.brand h1{font-size:20px;letter-spacing:1px}.brand p{font-size:11px;color:#dbeafe}
.stats{display:flex;gap:6px;font-size:13px}.pill{background:rgba(255,255,255,.16);border:1px solid rgba(255,255,255,.2);border-radius:999px;padding:5px 8px;font-weight:900}
#gameBox{position:relative;flex:1;min-height:430px;background:linear-gradient(#78c6ff 0%,#dff6ff 58%,#80d56f 58%,#58b957 100%);border-radius:24px;overflow:hidden;border:3px solid rgba(255,255,255,.3);box-shadow:0 15px 40px rgba(0,0,0,.35);touch-action:none}
.road{position:absolute;left:0;bottom:0;width:100%;height:42%;background:linear-gradient(#585858,#303030);clip-path:polygon(35% 0,65% 0,100% 100%,0 100%)}
.lane-line{position:absolute;left:50%;bottom:0;width:8px;height:70px;background:#facc15;transform:translateX(-50%);border-radius:10px;animation:roadLine .3s linear infinite}
@keyframes roadLine{from{bottom:42%;opacity:0}to{bottom:-80px;opacity:1}}
.cloud{position:absolute;width:80px;height:28px;background:rgba(255,255,255,.85);border-radius:40px;animation:cloudMove 16s linear infinite}
.cloud:before,.cloud:after{content:"";position:absolute;background:rgba(255,255,255,.9);border-radius:50%}
.cloud:before{width:34px;height:34px;left:12px;top:-16px}.cloud:after{width:42px;height:42px;left:34px;top:-22px}
.cloud.one{top:55px;left:20px}.cloud.two{top:115px;left:260px;animation-duration:22s}
@keyframes cloudMove{from{transform:translateX(0)}to{transform:translateX(-520px)}}
.hud{position:absolute;top:12px;left:12px;background:rgba(15,23,42,.82);border:2px solid rgba(255,255,255,.22);border-radius:16px;padding:10px 12px;z-index:6;font-weight:900;box-shadow:0 8px 20px rgba(0,0,0,.28)}
.pause-btn{position:absolute;right:12px;top:12px;width:48px;height:48px;padding:0;border-radius:16px;z-index:7;font-size:22px;background:linear-gradient(135deg,#2563eb,#0f172a);box-shadow:0 5px 0 #020617;color:white}
#player{position:absolute;width:58px;height:76px;left:50%;bottom:48px;transform:translateX(-50%);z-index:4;filter:drop-shadow(0 8px 4px rgba(0,0,0,.35));animation:runBounce .65s ease-in-out infinite alternate}
#player:before{content:"😎";position:absolute;left:11px;top:0;font-size:34px;z-index:2}
#player:after{content:"";position:absolute;left:12px;top:32px;width:35px;height:40px;background:linear-gradient(#fb923c,#ea580c);border-radius:16px 16px 9px 9px;box-shadow:0 5px 0 #9a3412}
.leg{position:absolute;bottom:0;width:12px;height:18px;background:#1e293b;border-radius:8px;z-index:1}.leg.l{left:14px;animation:leg1 .35s infinite alternate}.leg.r{right:14px;animation:leg2 .45s infinite alternate}
@keyframes runBounce{from{transform:translateX(-50%) translateY(0) rotate(-1deg)}to{transform:translateX(-50%) translateY(-5px) rotate(1deg)}}
@keyframes leg1{to{transform:rotate(18deg)}}@keyframes leg2{to{transform:rotate(-18deg)}}
.obstacle{position:absolute;width:45px;height:45px;border-radius:12px;background:linear-gradient(#ef4444,#991b1b);box-shadow:0 5px 0 #7f1d1d;z-index:3}
.obstacle:after{content:"⚠️";position:absolute;inset:0;display:flex;justify-content:center;align-items:center;font-size:22px}
.coin{position:absolute;width:34px;height:34px;border-radius:50%;background:radial-gradient(circle at 30% 30%,#fff7ad,#facc15,#d97706);box-shadow:0 0 14px rgba(250,204,21,.8);z-index:3}
.coin:after{content:"★";position:absolute;inset:0;display:flex;justify-content:center;align-items:center;color:#92400e;font-size:17px}
.shield{position:absolute;width:36px;height:36px;z-index:3}.shield:after{content:"🛡️";font-size:32px}
#messageScreen{position:absolute;inset:0;background:url('data:image/png;base64,') center/cover no-repeat,rgba(15,23,42,.8);z-index:10;display:flex;justify-content:center;align-items:center;text-align:center;padding:20px}
.panel{background:linear-gradient(135deg,rgba(15,23,42,.78),rgba(30,64,175,.55));border:2px solid rgba(255,255,255,.28);border-radius:28px;padding:24px;max-width:330px;box-shadow:0 20px 45px rgba(0,0,0,.45)}
.panel h2{font-size:34px;margin-bottom:8px}.panel p{font-size:14px;color:#e2e8f0;margin-bottom:14px;line-height:1.5}
button{border:none;border-radius:18px;padding:14px 24px;background:linear-gradient(135deg,#facc15,#f97316);color:#111827;font-size:16px;font-weight:900;cursor:pointer;box-shadow:0 6px 0 #9a3412;text-transform:uppercase;letter-spacing:.5px}
button:active{transform:translateY(3px);box-shadow:0 2px 0 #9a3412}
.controls{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.control-btn{padding:18px;font-size:26px;background:linear-gradient(135deg,rgba(37,99,235,.9),rgba(15,23,42,.92));border:2px solid rgba(255,255,255,.25);box-shadow:0 6px 0 rgba(2,6,23,.8);color:white;user-select:none}
.shield-mode #player{filter:drop-shadow(0 0 15px rgba(34,211,238,1))}
#player.hit{animation:hitShake .13s linear}
@keyframes hitShake{0%{transform:translateX(-50%)}25%{transform:translateX(calc(-50% - 8px))}50%{transform:translateX(calc(-50% + 8px))}100%{transform:translateX(-50%)}}
</style>
</head>
<body>
<div class="game-wrapper">
  <div class="top-bar">
    <div class="brand"><h1>🏃 RunawayNandan</h1><p>Pro 2D Web Game</p></div>
    <div class="stats">
      <div class="pill">⭐ <span id="score">0</span></div>
      <div class="pill">🏆 <span id="bestScore">0</span></div>
      <div class="pill">🛡️ <span id="shieldText">OFF</span></div>
    </div>
  </div>
  <div id="gameBox">
    <div class="cloud one"></div><div class="cloud two"></div><div class="road"></div><div class="lane-line"></div>
    <div class="hud"><div>❤️ <span id="livesText">3</span></div><div>🎯 Lv <span id="levelText">1</span></div></div>
    <button id="pauseBtn" class="pause-btn">⏸</button>
    <div id="player"><div class="leg l"></div><div class="leg r"></div></div>
    <div id="messageScreen"><div class="panel"><h2>RunawayNandan</h2><p>Dodge danger, collect star coins, use shield and survive longer.</p><button onclick="startGame()">Start Game</button></div></div>
  </div>
  <div class="controls"><button class="control-btn" id="leftBtn">⬅️</button><button class="control-btn" id="rightBtn">➡️</button></div>
</div>
<script>
const gameBox=document.getElementById("gameBox"),player=document.getElementById("player"),scoreEl=document.getElementById("score"),bestScoreEl=document.getElementById("bestScore"),shieldText=document.getElementById("shieldText"),livesText=document.getElementById("livesText"),levelText=document.getElementById("levelText"),pauseBtn=document.getElementById("pauseBtn"),messageScreen=document.getElementById("messageScreen");
let gameRunning=false,score=0,lives=3,level=1,paused=false,bestScore=localStorage.getItem("runawayBest")||0,playerX=50,speed=3,shieldActive=false,shieldTimeout=null,items=[],lastSpawnTime=0;
bestScoreEl.textContent=bestScore;
function startGame(){gameRunning=true;score=0;lives=3;level=1;paused=false;speed=3;playerX=50;shieldActive=false;pauseBtn.textContent="⏸";items.forEach(i=>i.element.remove());items=[];messageScreen.style.display="none";gameBox.classList.remove("shield-mode");updatePlayerPosition();updateStats();requestAnimationFrame(gameLoop)}
function updatePlayerPosition(){if(playerX<15)playerX=15;if(playerX>85)playerX=85;player.style.left=playerX+"%"}
function movePlayer(d){if(!gameRunning||paused)return;playerX+=d*10;updatePlayerPosition()}
function createFallingItem(){const r=Math.random();let type="obstacle";if(r>.6&&r<=.85)type="coin";if(r>.85)type="shield";const e=document.createElement("div");e.className=type;const x=18+Math.random()*64;e.style.left=x+"%";e.style.top="-55px";gameBox.appendChild(e);items.push({element:e,type:type,y:-55,x:x})}
function moveItems(){for(let i=items.length-1;i>=0;i--){const item=items[i];item.y+=speed;item.element.style.top=item.y+"px";if(checkCollision(player,item.element))handleCollision(item,i);if(item.y>gameBox.clientHeight+60){item.element.remove();items.splice(i,1)}}}
function handleCollision(item,index){item.element.remove();items.splice(index,1);if(item.type==="coin"){score+=10}else if(item.type==="shield"){activateShield()}else{if(shieldActive){score+=5}else{lives--;player.classList.add("hit");setTimeout(()=>player.classList.remove("hit"),180);if(lives<=0)endGame()}}}
function activateShield(){shieldActive=true;shieldText.textContent="ON";gameBox.classList.add("shield-mode");clearTimeout(shieldTimeout);shieldTimeout=setTimeout(()=>{shieldActive=false;shieldText.textContent="OFF";gameBox.classList.remove("shield-mode")},5000)}
function checkCollision(a,b){const A=a.getBoundingClientRect(),B=b.getBoundingClientRect();return !(A.right<B.left||A.left>B.right||A.bottom<B.top||A.top>B.bottom)}
function updateStats(){level=Math.floor(score/400)+1;scoreEl.textContent=score;bestScoreEl.textContent=bestScore;livesText.textContent=lives;levelText.textContent=level}
function endGame(){gameRunning=false;clearTimeout(shieldTimeout);if(score>bestScore){bestScore=score;localStorage.setItem("runawayBest",bestScore)}updateStats();messageScreen.style.display="flex";messageScreen.innerHTML=`<div class="panel"><h2>Game Over</h2><p>Your Score: <b>${score}</b><br>Best Score: <b>${bestScore}</b></p><p>Tip: Collect shield before risky moves.</p><button onclick="startGame()">Play Again</button></div>`}
function gameLoop(time){if(!gameRunning)return;if(paused){requestAnimationFrame(gameLoop);return}if(time-lastSpawnTime>Math.max(430,850-level*35)){createFallingItem();lastSpawnTime=time}score++;speed=3+score/650+level*.15;moveItems();updateStats();requestAnimationFrame(gameLoop)}
pauseBtn.addEventListener("click",()=>{if(!gameRunning)return;paused=!paused;pauseBtn.textContent=paused?"▶":"⏸"});
document.getElementById("leftBtn").addEventListener("click",()=>movePlayer(-1));document.getElementById("rightBtn").addEventListener("click",()=>movePlayer(1));
window.addEventListener("keydown",e=>{if(e.key==="ArrowLeft")movePlayer(-1);if(e.key==="ArrowRight")movePlayer(1);if(e.key===" ")pauseBtn.click()});
let touchStartX=0;gameBox.addEventListener("touchstart",e=>touchStartX=e.touches[0].clientX);gameBox.addEventListener("touchend",e=>{const diff=e.changedTouches[0].clientX-touchStartX;if(diff>30)movePlayer(1);if(diff<-30)movePlayer(-1)});
</script>
</body>
</html>
